# -------------------------------------------------
# Environment Configuration for IndiaNext Supply Chain Backend
# -------------------------------------------------
# Copy this file to .env and fill in the values.

# Port on which the Express server will run
PORT=5000

# ---- Blockchain Configuration ----

# Polygon Amoy Testnet RPC URL (e.g. from Alchemy or Infura)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology

# Private key of the deployer wallet (DO NOT commit the real key!)
DEPLOYER_PRIVATE_KEY=your_wallet_private_key_here

# Deployed SupplyChain contract address
CONTRACT_ADDRESS=your_deployed_contract_address_here

# ---- IPFS / Pinata Configuration ----

# Pinata JWT (get from https://app.pinata.cloud → API Keys)
PINATA_JWT=your_pinata_jwt_here

# Pinata gateway URL for resolving CIDs
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
