# -------------------------------------------------
# Environment Configuration for IndiaNext Supply Chain Backend
# -------------------------------------------------
# Copy this file to .env and fill in the values.

# Port on which the Express server will run
PORT=5000

# ---- Blockchain Configuration ----

# Polygon Amoy Testnet RPC URL (e.g. from Alchemy or Infura)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology

# Private key of the deployer wallet (DO NOT commit the real key!)
DEPLOYER_PRIVATE_KEY=your_wallet_private_key_here

